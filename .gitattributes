# Normaliza todos os arquivos de texto para LF no repositório
* text=auto eol=lf

# Arquivos Windows que precisam de CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binários — não tocar
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.gz binary
